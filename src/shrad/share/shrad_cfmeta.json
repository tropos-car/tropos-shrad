{
    "attributes": {
        "title"           : "TROPOS GUVis-3511 shadow band radiometer observations",
        "institution"     : "Leibniz Institute for Tropospheric Research (TROPOS)",
        "department"      : "Remote Sensing of Atmospheric Processes",
        "department_team" : "Clouds, Aerosol and Radiation",
        "address"         : "Permoser Str. 15, 04318 Leipzig, Germany",
        "source"          : "TROPOS GUVis-3511 (Biospherical Inc.)",
        "contact_person"  : "Andreas Macke and the clouds, aerosol and radiation team of the remote sensing department, mailto:andreas.macke@tropos.de",
        "contributor_name": "{contributor_name}",
        "contributor_role": "{contributor_role}",
        "authors_software": "Jonas Witthuhn",
        "creator_name"    : "{creator_name}",
        "project"         : "{project}",
        "site"            : "{campaign}",
        "references"      : [
            "https://doi.org/10.5194/amt-10-709-2017",
            "https://doi.org/10.5194/amt-13-1387-2020"
        ],
        "standard_name_vocabulary" : "CF Standard Name Table v81",
        "conventions"     : "CF-1.10, ACDD-1.3",
        "license"         : "CC-BY-SA 3.0"
    },
    "variables": {
        // FLUX -----------------------------------------------
        "flxsp" :{},
        "flxbb" :{},
        // SPECTRAL BANDS -----------------------------------------------
        "band_wvl":{},
        "band_wvlc":{},
        "band_width":{},
        // BIOSHADE ----------------------------------------------------
        "shade_mode": {
            "type":"u1",
            "attributes":{
                "long_name": "Flags describing shadowband mode",
                "meaning": [
                    "home_position",
                    "park_position",
                    "moving_towards_home",
                    "moving_towards_park"
                ],
                "zlib": true
            }
        },
        "shade_angle": {},
        // SENSOR STATUS -----------------------------------------------
        "sensor_temp":{},
        "sensor_pitch":{
            "type": "i4",
            "attributes": {
                "standard_name": "platform_pitch",
                "units": "deg",
                "scale_factor": 1e-2,
                "_FillValue": 2147483647,
                "zlib": true
            }
        },
        "sensor_roll":{
            "type": "i4",
            "attributes": {
                "standard_name": "platform_roll",
                "units": "deg",
                "scale_factor": 1e-2,
                "_FillValue": 2147483647,
                "zlib": true
            }
        },
        "sensor_yaw":{
            "type": "i4",
            "attributes": {
                "standard_name": "platform_yaw",
                "units": "deg",
                "scale_factor": 1e-2,
                "_FillValue": 2147483647,
                "zlib": true
            }
        },
        "sensor_tilt": {
            "type": "u2",
            "attributes": {
                "standard_name": "sensor_zenith_angle",
                "units": "degree",
                "scale_factor": 0.1,
                "add_offset": -360,
                "valid_range": [
                0,7200
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        "sensor_status": {
            "type": "u2",
            "attributes":{
                "units": "",
                "standard_name": "status_flag",
                "_FillValue": 65535,
                "zlib":true
            }
        },
        // METEOROLOGICAL -----------------------------------------------
        "temp_air": {
            "type": "u2",
            "attributes": {
                "units": "K",
                "long_name": "air temperature",
                "standard_name": "air_temperature",
                "scale_factor": 0.0016,
                "add_offset": 243.15,
                "_FillValue": 65535,
                "valid_range": [
                0,
                62500
                ],
                "zlib": true
            }
        },
        "relative_humidity": {
            "type": "u2",
            "attributes": {
                "units": "1",
                "long_name": "air relative humidity",
                "standard_name": "relative_humidity",
                "scale_factor": 0.000016,
                "add_offset": 0.0,
                "valid_range": [
                0,
                62500
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        "pressure": {
            "type": "u2",
            "attributes": {
                "units": "Pa",
                "long_name": "air pressure",
                "standard_name": "air_pressure",
                "scale_factor": 0.4,
                "add_offset": 85000,
                "valid_range": [
                0,
                62500
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        // SUN POSITION -----------------------------------------------
        "szen": {
            "type": "u2",
            "attributes": {
                "standard_name": "solar_zenith_angle",
                "units": "degree",
                "scale_factor": 0.005,
                "add_offset": 0.0,
                "valid_range": [
                0,
                36000
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        "sazi": {
            "type": "u2",
            "attributes": {
                "standard_name": "solar_azimuth_angle",
                "units": "degree",
                "scale_factor": 0.01,
                "add_offset": 0.0,
                "valid_range": [
                0,
                36000
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        "esd": {
            "type": "u2",
            "attributes": {
                "standard_name": "earth_sun_distance",
                "units": "AU",
                "scale_factor": 0.000001,
                "add_offset": 0.98,
                "valid_range": [
                0,
                40000
                ],
                "_FillValue": 65535,
                "zlib": true
            }
        },
        // COORDINATES -----------------------------------------------
        "lat": {
            "type": "u4",
            "attributes": {
                "standard_name": "latitude",
                "units": "degree_north",
                "scale_factor": 1e-6,
                "add_offset": -90,
                "valid_range": [
                0,
                180e6
                ],
                "_FillValue": 4294967295,
                "zlib": true
            }
        },
        "lon": {
            "type": "u4",
            "attributes": {
                "standard_name": "longitude",
                "units": "degree_east",
                "scale_factor": 1e-6,
                "add_offset": -180,
                "valid_range": [
                0,
                360e6
                ],
                "_FillValue": 4294967295,
                "zlib": true
            }
        },
        "altitude": {
            "type": "i2",
            "attributes": {
                "standard_name": "altitude",
                "units": "m",
                "_FillValue": -1,
                "zlib": true
            }
        }
    }
}